<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Identificación - Nalgueada Express</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Arial, sans-serif; }
        body { background-color: #005691; color: #FFFFFF; display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; }
        .container { max-width: 400px; width: 100%; text-align: center; }
        .logo { max-width: 120px; margin-bottom: 20px; }
        h2 { margin-bottom: 10px; }
        p { margin-bottom: 25px; opacity: 0.8; font-size: 0.9rem; }
        input { width: 100%; padding: 15px; border-radius: 10px; border: none; font-size: 1.1rem; background: #FFFFFF; color: #005691; margin-bottom: 15px; }
        .btn-main { width: 100%; padding: 15px; background: #FDB813; color: #000; border-radius: 50px; font-weight: bold; border: none; cursor: pointer; text-transform: uppercase; }
        .btn-main:disabled { background: #666; cursor: wait; }
        #msg { margin-top: 15px; font-size: 0.85rem; font-weight: bold; }
        .hidden { display: none; }
    </style>
</head>
<body>

    <div class="container">
        <img src="logo_nalgueada_solid.png" class="logo">
        
        <div id="step-1">
            <h2>¡Hola de nuevo!</h2>
            <p>Ingresa tu WhatsApp para continuar.</p>
            <input type="tel" id="tel-input" placeholder="5512345678" maxlength="10">
            <button id="btn-buscar" class="btn-main" onclick="buscarCliente()">Buscar Cliente</button>
        </div>

        <div id="step-2" class="hidden">
            <h2 id="welcome-user">Bienvenido</h2>
            <p>Confirma tu dirección para este pedido:</p>
            <input type="text" id="dir-input" placeholder="Calle, número y colonia">
            <button id="btn-finalizar" class="btn-main" onclick="actualizarYEntrar()">Continuar al Menú</button>
        </div>
        
        <div id="msg"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        const S_URL = 'https://jyvboqhppybuiivwfvlr.supabase.co';
        const S_KEY = 'sb_publishable_vY2mFGcPgE8FZ77z8XfQNQ_MyB3b68f12cc1214040f9000f68f17665796a583e'; 
        const _supabase = supabase.createClient(S_URL, S_KEY);

        let clienteActual = null;

        function getCoords() {
            return new Promise((resolve, reject) => {
                navigator.geolocation.getCurrentPosition(
                    (pos) => resolve(`${pos.coords.latitude},${pos.coords.longitude}`),
                    (err) => reject("GPS_DENIED"),
                    { enableHighAccuracy: true, timeout: 8000 }
                );
            });
        }

        async function buscarCliente() {
            const tel = document.getElementById('tel-input').value;
            if (tel.length < 10) return;

            document.getElementById('btn-buscar').disabled = true;
            
            try {
                const { data, error } = await _supabase
                    .from('clientes')
                    .select('*')
                    .eq('whatsapp', tel)
                    .single();

                if (error || !data) {
                    document.getElementById('msg').innerHTML = "❌ Número no registrado.";
                    document.getElementById('btn-buscar').disabled = false;
                    return;
                }

                clienteActual = data;
                document.getElementById('step-1').classList.add('hidden');
                document.getElementById('step-2').classList.remove('hidden');
                document.getElementById('welcome-user').innerText = `¡Hola, ${data.nombre}!`;
                document.getElementById('dir-input').value = data.direccion;
                document.getElementById('msg').innerHTML = "";

            } catch (err) {
                document.getElementById('msg').innerHTML = "❌ Error de conexión.";
            }
        }

        async function actualizarYEntrar() {
            const nuevaDir = document.getElementById('dir-input').value;
            const btn = document.getElementById('btn-finalizar');
            const msg = document.getElementById('msg');

            btn.disabled = true;
            msg.innerHTML = "📡 Actualizando ubicación GPS...";

            try {
                const coords = await getCoords();
                const mapsLink = `https://www.google.com/maps?q=${coords}`;

                // Actualizar en BD
                const { error } = await _supabase
                    .from('clientes')
                    .update({ 
                        direccion: nuevaDir, 
                        referencia: mapsLink 
                    })
                    .eq('whatsapp', clienteActual.whatsapp);

                if (error) throw error;

                // Guardar sesión local
                localStorage.setItem('cliente_nombre', clienteActual.nombre);
                localStorage.setItem('cliente_whatsapp', clienteActual.whatsapp);

                msg.innerHTML = "✅ Datos actualizados. Entrando...";
                setTimeout(() => window.location.replace('menu.html'), 1000);

            } catch (err) {
                msg.innerHTML = "❌ Error: Activa el GPS para continuar.";
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
